{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["node", "@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@steed/shared": ["./packages/shared/src/index.ts"],
      "@steed/api/*": ["./packages/api/src/*/index.ts"]
    }
  },
  "include": [
    "packages/shared/src/**/*",
    "packages/worker/src/**/*",
    "packages/cli/src/**/*",
    "packages/api/src/**/*",
    "apps/web/src/**/*",
    "apps/web/worker/**/*"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "apps/web_legacy/**"
  ]
}
