#!/bin/sh
# Pre-commit hook: G1 + L1 in parallel (<30s target)

set -e

echo "🔍 Running pre-commit checks..."

ROOT_DIR=$(pwd)

# Run G1 (typecheck + lint) and L1 (test + coverage) in parallel
bun run typecheck &
pid_typecheck=$!

bun run lint &
pid_lint=$!

bun run test &
pid_test=$!

# Dashboard tests run separately (jsdom environment)
(cd packages/dashboard && bun vitest run --coverage) &
pid_dashboard=$!

# Wait for all and collect exit codes
wait $pid_typecheck
exit_typecheck=$?

wait $pid_lint
exit_lint=$?

wait $pid_test
exit_test=$?

wait $pid_dashboard
exit_dashboard=$?

# Check coverage after tests complete
if [ $exit_test -eq 0 ]; then
  bun run check-coverage
  exit_coverage=$?
else
  exit_coverage=1
fi

# Report results
echo ""
if [ $exit_typecheck -eq 0 ] && [ $exit_lint -eq 0 ] && [ $exit_test -eq 0 ] && [ $exit_coverage -eq 0 ] && [ $exit_dashboard -eq 0 ]; then
  echo "✅ All pre-commit checks passed"
  exit 0
else
  echo "❌ Pre-commit checks failed:"
  [ $exit_typecheck -ne 0 ] && echo "   - typecheck failed"
  [ $exit_lint -ne 0 ] && echo "   - lint failed"
  [ $exit_test -ne 0 ] && echo "   - test failed"
  [ $exit_coverage -ne 0 ] && echo "   - coverage below threshold"
  [ $exit_dashboard -ne 0 ] && echo "   - dashboard tests failed"
  exit 1
fi
