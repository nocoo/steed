{
  "name": "@steed/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "steed": "./dist/bin/steed.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build src/bin/steed.ts --outdir dist/bin --target node && bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/bin/steed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nocoo/cli-base": "file:../../../cli-base",
    "@steed/shared": "workspace:*",
    "chalk": "^5.6.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4"
  }
}
