{
  "name": "@steed/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --env dev --local --persist-to .wrangler/state/web",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
